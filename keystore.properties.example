## Copy to android/keystore.properties (never commit the real file).
## Path storeFile is relative to the android/ folder.
##
## Create the keystore once (from android/):
##   keytool -genkeypair -v -storetype PKCS12 -keystore app/bazariyatrou-release.jks -alias bazariyatrou -keyalg RSA -keysize 2048 -validity 10000
##
storeFile=app/bazariyatrou-release.jks
storePassword=CHANGE_ME
keyAlias=bazariyatrou
keyPassword=CHANGE_ME
